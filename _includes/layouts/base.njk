<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title | default: "WDR5 Connect" }}</title>
  <meta name="description" content="{{ description | default: "Connecting families affected by WDR5-related neurodevelopmental disorder." }}">
  <link rel="stylesheet" href="/assets/styles.css">
  <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
</head>
<body>
  <header class="site-header">
    <div class="container nav-wrap">
      <a class="brand" href="/">WDR5 Connect</a>
      <nav class="site-nav" aria-label="Main navigation">
        <a href="/">Home</a>
        <a href="/about/">About WDR5</a>
        <a href="/story/">Our Story</a>
        <a href="/updates/">Updates</a>
        <a href="/resources/">Resources</a>
        <a href="/contact/">Contact</a>
        <a class="nav-button" href="/registry/">Join the Registry</a>
      </nav>
    </div>
  </header>

  <main>
    {{ content | safe }}
  </main>

  <footer class="site-footer">
    <div class="container footer-grid">
      <div>
        <strong>WDR5 Connect</strong>
        <p>Connecting families, sharing lived experience and supporting research into WDR5-related neurodevelopmental disorder.</p>
      </div>
      <div>
        <p><a href="/contact/">Contact us</a></p>
        <p><a href="/registry/">Join the family registry</a></p>
      </div>
    </div>
  </footer>

  <script>
    if (window.netlifyIdentity) {
      window.netlifyIdentity.on("init", user => {
        if (!user) {
          window.netlifyIdentity.on("login", () => {
            document.location.href = "/admin/";
          });
        }
      });
    }
  </script>
</body>
</html>
