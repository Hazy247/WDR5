---
layout: layouts/base.njk
---

<article class="post">
  <div class="container narrow">
    <p class="update-date">{{ date | readableDate }}</p>
    <h1>{{ title }}</h1>

    {% if image %}
      <img class="post-hero-image" src="{{ image }}" alt="{{ imageAlt }}">
    {% endif %}

    <div class="post-content">
      {{ content | safe }}
    </div>

    <p><a class="text-link" href="/WDR5/updates/">← Back to updates</a></p>
  </div>
</article>
